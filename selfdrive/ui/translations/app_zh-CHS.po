#: selfdrive/ui/sunnypilot/layouts/settings/visuals.py

msgid "Display useful metrics below the chevron that tracks the lead car only applicable to cars with sunnypilot longitudinal control."
msgstr "在引导车下方显示实用指标，仅适用于搭载 sunnypilot 纵向控制的车型。"

msgid "This feature requires sunnypilot longitudinal control to be available."
msgstr "此功能需要开启 sunnypilot 纵向控制。"

msgid "Show Blind Spot Warnings"
msgstr "显示盲区预警"

msgid "Enabling this will display warnings when a vehicle is detected in your blind spot as long as your car has BSM supported."
msgstr "开启后，若车辆支持 BSM，检测到盲区有车时会显示预警。"

msgid "Steering Arc"
msgstr "转向弧线"

msgid "Display steering arc on the driving screen when lateral control is enabled."
msgstr "横向控制激活时，在驾驶界面显示转向弧线。"

msgid "Enable Tesla Rainbow Mode"
msgstr "启用特斯拉彩虹模式"

msgid "A beautiful rainbow effect on the path the model wants to take. It does not affect driving in any way."
msgstr "在规划路径上显示彩虹效果，不影响任何驾驶行为。"

msgid "Enable Standstill Timer"
msgstr "启用停车计时器"

msgid "Show a timer on the HUD when the car is at a standstill."
msgstr "车辆静止时，在 HUD 上显示计时。"

msgid "Display Road Name"
msgstr "显示道路名称"

msgid "Displays the name of the road the car is traveling on.<br>The OpenStreetMap database of the location must be downloaded from the OSM panel to fetch the road name."
msgstr "显示当前行驶道路名称。<br>需在 OSM 面板下载对应地区的地图数据。"

msgid "Green Traffic Light Alert (Beta)"
msgstr "绿灯提醒（测试版）"

msgid "A chime and on-screen alert will play when the traffic light you are waiting for turns green and you have no vehicle in front of you.<br>Note: This chime is only designed as a notification. It is the driver's responsibility to observe their environment and make decisions accordingly."
msgstr "前方无车且红灯变绿时，播放提示音并弹窗。<br>注意:仅为提醒功能，驾驶员需观察环境自主操作。"

msgid "Lead Departure Alert (Beta)"
msgstr "前车起步提醒（测试版）"

msgid "A chime and on-screen alert will play when you are stopped, and the vehicle in front of you start moving.<br>Note: This chime is only designed as a notification. It is the driver's responsibility to observe their environment and make decisions accordingly."
msgstr "停车时前车起步，会播放提示音并弹窗。<br>注意:仅为提醒功能，驾驶员需观察环境自主操作。"

msgid "Speedometer: Always Display True Speed"
msgstr "时速表:始终显示真实车速"

msgid "For applicable vehicles, always display the true vehicle current speed from wheel speed sensors."
msgstr "对支持车型，始终显示来自轮速传感器的真实车速。"

msgid "Speedometer: Hide from Onroad Screen"
msgstr "时速表:在行驶界面隐藏"

